{
  "name": "veste_app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test --config=e2e/playwright.config.js",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{vue,js,css}\"",
    "deploy": "npm run build && touch dist/.nojekyll && gh-pages -d dist"
  },
  "lint-staged": {
    "*.{vue,js}": "eslint --fix",
    "*.{vue,js,css}": "prettier --write"
  },
  "dependencies": {
    "cropperjs": "^2.1.1",
    "dexie": "^4.4.3",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "fake-indexeddb": "^6.2.5",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
